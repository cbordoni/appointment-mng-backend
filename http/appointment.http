@baseUrl = http://localhost:3000
@json = application/json
@storeId = 11111111-1111-4111-8111-111111111111
@clientId = 33333333-3333-4333-8333-333333333333
@professionalId = 44444444-4444-4444-8444-444444444444
@appointmentId = 55555555-5555-4555-8555-555555555555

### List appointments by date range
GET {{baseUrl}}/appointments?storeId={{storeId}}&from=2026-03-01T00:00:00.000Z&to=2026-03-31T23:59:59.999Z

### List appointments by client
GET {{baseUrl}}/appointments/client/{{clientId}}?storeId={{storeId}}&page=1&limit=10

### List appointments by professional
GET {{baseUrl}}/appointments/professional/{{professionalId}}?storeId={{storeId}}&page=1&limit=10

### Get appointment by id
GET {{baseUrl}}/appointments/{{appointmentId}}

### Create appointment
POST {{baseUrl}}/appointments
Content-Type: {{json}}

{
  "summary": "Consulta de rotina",
  "description": "Paciente com sintomas leves",
  "dtStart": "2026-03-30T09:00:00.000Z",
  "dtEnd": "2026-03-30T09:30:00.000Z",
  "timezone": "America/Sao_Paulo",
  "status": "CONFIRMED",
  "clientId": "{{clientId}}",
  "professionalId": "{{professionalId}}"
}

### Update appointment
PATCH {{baseUrl}}/appointments/{{appointmentId}}
Content-Type: {{json}}

{
  "summary": "Consulta de retorno",
  "description": null,
  "status": "TENTATIVE"
}

### Delete appointment
DELETE {{baseUrl}}/appointments/{{appointmentId}}
