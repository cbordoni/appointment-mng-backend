@baseUrl = http://localhost:3000
@json = application/json
@storeId = 11111111-1111-4111-8111-111111111111
@appointmentId = 55555555-5555-4555-8555-555555555555
@appointmentExceptionId = 66666666-6666-4666-8666-666666666666

### List appointment exceptions
GET {{baseUrl}}/appointment-exceptions?page=1&limit=10
x-store-id: {{storeId}}

### Get appointment exception by id
GET {{baseUrl}}/appointment-exceptions/{{appointmentExceptionId}}

### Create appointment exception
POST {{baseUrl}}/appointment-exceptions
Content-Type: {{json}}

{
  "appointmentId": "{{appointmentId}}",
  "exdate": "2026-03-31T09:00:00.000Z"
}

### Update appointment exception
PATCH {{baseUrl}}/appointment-exceptions/{{appointmentExceptionId}}
Content-Type: {{json}}

{
  "exdate": "2026-04-07T09:00:00.000Z"
}

### Delete appointment exception
DELETE {{baseUrl}}/appointment-exceptions/{{appointmentExceptionId}}
